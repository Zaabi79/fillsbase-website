RewriteEngine On
RewriteBase /

# Redirect WHMCS login/register to custom pages
RewriteCond %{QUERY_STRING} rp=/login
RewriteRule ^index\.php$ /login [R=302,L]
RewriteCond %{QUERY_STRING} rp=/register
RewriteRule ^index\.php$ /register [R=302,L]

# Redirect deprecated store page
RewriteRule ^store/hebergement-web/?$ hosting [R=301,L,NC]
RewriteRule ^checkout/?$ index.php [R=301,L,NC]
RewriteRule ^database/?$ index.php [R=301,L,NC]
RewriteRule ^ddos/?$ index.php [R=301,L,NC]
RewriteRule ^colocation/?$ index.php [R=301,L,NC]

# Domain checker — use custom wrapper
RewriteRule ^domainchecker/?$ domainchecker_custom.php [L,NC,QSA]

# Knowledgebase routing
RewriteRule ^knowledgebase/([0-9]+)/.*\.html$ knowledgebase.php?action=displayarticle&id=$1 [L,NC,QSA]
RewriteRule ^knowledgebase/([0-9]+)/([^/]*)$ knowledgebase.php?action=displaycat&id=$1 [L,NC,QSA]
RewriteRule ^knowledgebase/?$ knowledgebase.php [L,NC]
RewriteRule ^knowledgebase-list/?$ knowledgebase.php [L,NC,QSA]

# Contact page
RewriteRule ^contact/?$ contact.php [L,NC,QSA]

# WHMCS direct PHP pages
RewriteRule ^(cart|clientarea|register|login|logout|dologin|pwreset|submitticket|supporttickets|viewticket|viewinvoice|viewquote|creditcard|whois|serverstatus|announcements|downloads|dl|affiliates|unsubscribe|upgrade|configuressl|networkissues|banned)/?$ $1.php [L,NC,QSA]

# All other extensionless URLs through index.php dispatcher (handles .html and .php)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^.]+)$ index.php [L,QSA]

DirectoryIndex index.php index.html
